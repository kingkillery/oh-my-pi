{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gopk-clips",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-22",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "gopk.xyz",
			"custom_domain": true
		}
	],
	"r2_buckets": [
		{
			"binding": "CLIPS_BUCKET",
			"bucket_name": "gopk-clips"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"send_email": [
		{
			"name": "EMAIL"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gopk-clips-db",
			"database_id": "7e6227fe-d27a-4519-a7bf-67797c48e0e3"
		}
	],
	"rules": [
		{
			"type": "Text",
			"globs": ["**/*.html"],
			"fallthrough": true
		}
	]
}
