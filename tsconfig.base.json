{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"lib": ["ES2024", "DOM.AsyncIterable"],
		"moduleResolution": "Bundler",
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"allowArbitraryExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		// TS1149/TS1261 on Windows means the shell cwd casing doesn't match the
		// on-disk path. The canonical checkout is C:\dev\Desktop-Projects\...
		// (capital D, capital P) — cd there before running typechecks; do not
		// relax this flag to hide the mismatch.
		"forceConsistentCasingInFileNames": true,
		"types": ["bun", "assets"],
		"typeRoots": ["./types", "./node_modules/@types"]
	}
}
